# ──────────────────────────────────────────────────────────────────────────
# Family Budget AI Pro — variáveis de ambiente
# Copia este ficheiro para `.env.local` e preenche com as tuas credenciais.
# ──────────────────────────────────────────────────────────────────────────

# Supabase ───────────────────────────────────────────────────────────────
# Encontra estes valores em: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Chave de serviço (NUNCA exposta ao cliente — usada apenas em rotas de API).
# Necessária para operações privilegiadas no servidor.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Claude / Anthropic ─────────────────────────────────────────────────────
# Cria a tua chave em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Modelo a utilizar (opcional — por omissão usa o mais capaz).
ANTHROPIC_MODEL=claude-opus-4-8

# App ────────────────────────────────────────────────────────────────────
# URL pública da aplicação (usada nos redirecionamentos de autenticação).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
